{
  "info": {
    "name": "AgriPilot - API Agriculteurs (X-API-Key)",
    "description": "API publique AgriPilot (/agriculteurs/**). Auth: header X-API-Key = AGRIPILOT_PUBLIC_API_KEY.\n\nAVANT D'ENVOYER : ouvre la collection -> onglet Variables -> renseigne 'publicApiKey' (la cle publique du serveur) et au besoin 'baseUrl'. Le header X-API-Key est present dans chaque requete (onglet Headers).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://digi-creditrural-io.com", "type": "string" },
    { "key": "publicApiKey", "value": "COLLER_LA_CLE_PUBLIQUE_ICI", "type": "string" },
    { "key": "agencyId", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "creditId", "value": "", "type": "string" },
    { "key": "groupId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Agences",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/agriculteurs/agencies", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "agencies"] }
      }
    },
    {
      "name": "Portefeuille d'une agence",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": {
          "raw": "{{baseUrl}}/agriculteurs/agencies/{{agencyId}}/portfolio?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["agriculteurs", "agencies", "{{agencyId}}", "portfolio"],
          "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
        }
      }
    },
    {
      "name": "Agriculteurs (liste paginee)",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": {
          "raw": "{{baseUrl}}/agriculteurs/farmers?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["agriculteurs", "farmers"],
          "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
        }
      }
    },
    {
      "name": "Agriculteur (detail)",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/agriculteurs/farmers/{{clientId}}", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "farmers", "{{clientId}}"] }
      }
    },
    {
      "name": "Credits d'un agriculteur",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/agriculteurs/farmers/{{clientId}}/credits", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "farmers", "{{clientId}}", "credits"] }
      }
    },
    {
      "name": "Credit (detail)",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/agriculteurs/credits/{{creditId}}", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "credits", "{{creditId}}"] }
      }
    },
    {
      "name": "Cooperatives (liste paginee)",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": {
          "raw": "{{baseUrl}}/agriculteurs/cooperatives?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["agriculteurs", "cooperatives"],
          "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
        }
      }
    },
    {
      "name": "Cooperative (detail)",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/agriculteurs/cooperatives/{{groupId}}", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "cooperatives", "{{groupId}}"] }
      }
    },
    {
      "name": "Membres d'une cooperative",
      "request": {
        "method": "GET",
        "header": [ { "key": "X-API-Key", "value": "{{publicApiKey}}", "type": "text" } ],
        "url": {
          "raw": "{{baseUrl}}/agriculteurs/cooperatives/{{groupId}}/members?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["agriculteurs", "cooperatives", "{{groupId}}", "members"],
          "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ]
        }
      }
    },
    {
      "name": "Controle securite : sans cle -> 401",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/agriculteurs/agencies", "host": ["{{baseUrl}}"], "path": ["agriculteurs", "agencies"] }
      }
    }
  ]
}
